# ===========================================
# UNIVERSITY PORTAL - ENVIRONMENT VARIABLES
# ===========================================
# Скопируйте этот файл в .env.local и заполните реальными значениями
# НЕ коммитьте .env.local в репозиторий!
# ===========================================

# --- СЕТЬ ---
# IP адрес сервера для внешнего доступа
# Для локальной разработки: SERVER_IP=localhost
# Для доступа из сети: укажите ваш локальный IP (например, 192.168.x.x)
SERVER_IP=localhost

# --- БАЗА ДАННЫХ PostgreSQL ---
DB_USER=portal_user
DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
DB_NAME=portal_db
DB_PORT_HOST=5432

# URL для подключения (внутри Docker используется сервис 'db')
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# --- АВТОРИЗАЦИЯ (NextAuth) ---
# Сгенерируйте секрет: openssl rand -base64 32
AUTH_SECRET=<GENERATE_SECURE_SECRET>
AUTH_URL=http://${SERVER_IP}:3000
AUTH_TRUST_HOST=true

# --- S3 ХРАНИЛИЩЕ (MinIO) ---
MINIO_ROOT_USER=portal_admin
MINIO_ROOT_PASSWORD=<GENERATE_SECURE_PASSWORD>

# Внутренний адрес (для подключения из контейнера web)
S3_ENDPOINT=http://minio:9000
# Внешний адрес (для подключения из браузера)
S3_PUBLIC_ENDPOINT=http://${SERVER_IP}:9000

S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET_NAME=portal-documents
S3_REGION=us-east-1

# ===========================================
# ИНСТРУКЦИЯ ПО ГЕНЕРАЦИИ СЕКРЕТОВ:
# ===========================================
# 1. Пароль для БД/MinIO (минимум 32 символа):
#    openssl rand -base64 32
#    или: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. AUTH_SECRET (минимум 32 символа):
#    openssl rand -base64 32
#    или: npx auth-secret
# ===========================================
